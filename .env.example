# omv-vmmanager — environment variables
# ============================================================================
# Copy this file to `.env` and edit values for your install, or export
# them in your shell / systemd unit / docker-compose.
#
# Anything left blank uses the default documented below.
# ============================================================================


# --- HTTP server ------------------------------------------------------------

# Port the backend listens on.
# Default: 8080
#PORT=8080
# Address the backend binds to. 0.0.0.0 accepts connections on all
# interfaces (default for backward compat with HTTP-only installs).
# Set to 127.0.0.1 in HTTPS-fronted installs so the backend is only
# reachable through the Caddy reverse proxy.
#BIND_ADDR=0.0.0.0


# --- Libvirt connection -----------------------------------------------------

# libvirt URI used by the backend to talk to libvirtd.
# Default: qemu:///system
# Use qemu+ssh://user@host/system for remote libvirt (Phase 2 feature).
#LIBVIRT_URI=qemu:///system


# --- Data directory ---------------------------------------------------------
#
# Directory where the backend stores persistent state:
#   - users.json       (user accounts, bcrypt-hashed passwords)
#   - groups.json      (user group definitions)
#   - jwt.key          (JWT signing secret, auto-generated if absent)
#   - audit.log        (JSONL audit log, append-only)
#   - pool-purposes.json
#   - pools/           (libvirt pool storage: vmmanager-disks, ISOS)
#   - covers/          (uploaded VM cover images)
#
# On OpenMediaVault hosts the default is /opt/openmediavault/vmmanager
# (detected by the existence of /etc/openmediavault/config.xml). On
# bare-metal Debian the default is /opt/omv-vmmanager. Override here
# if neither is what you want.
#
# The backend creates this directory on first run (mode 0755).
#DATA_DIR=/opt/omv-vmmanager


# --- JWT secret -------------------------------------------------------------
#
# The backend refuses to start with the default placeholder. If you set this
# env var, use a strong random value (>= 32 chars from `openssl rand -base64 32`
# or similar). If unset, a random 256-bit secret is generated and persisted to
# {DATA_DIR}/jwt.key with 0600 perms on first run.
#
# Generate: openssl rand -base64 32
JWT_SECRET=


# --- Repository / source location ------------------------------------------
#
# Where the backend looks for helper scripts (setup-bridge.sh,
# disable-netplan.sh, etc.) and where the live source tree is mounted.
# Only relevant in dev / non-Docker installs; the docker-compose already sets
# this for the container.
#
# Note: REPO_DIR is the canonical name. The legacy WEBVM_REPO_DIR /
# WEBMV_REPO_DIR (transposed) are still accepted as fallbacks for
# compatibility with older systemd units.
#
# Default: DATA_DIR/source  (a symlink the installer creates)
#REPO_DIR=/opt/omv-vmmanager/source
# Legacy alias kept for backward compat. Don't use it in new installs.
#WEBVM_REPO_DIR=/opt/omv-vmmanager/source
#WEBMV_REPO_DIR=/opt/omv-vmmanager/source


# --- VNC proxy --------------------------------------------------------------
#
# Where the backend opens a TCP connection to reach libvirt's VNC port
# (5900 + display). On a regular install libvirtd listens on 127.0.0.1, so
# the default works. In Docker with `network_mode: host`, 127.0.0.1 is the
# host's loopback, so it also works. Override only if you have a custom
# libvirtd bind address.
#
# Default: 127.0.0.1
#VNC_PROXY_HOST=127.0.0.1


# --- Public host (client-facing) -------------------------------------------
#
# IP or hostname baked into the .rdp and .vv (SPICE) files the user
# downloads. MUST be reachable from the user's client machine — NOT from
# inside the container. Empty falls back to the first non-loopback IPv4
# of the running process (works for systemd installs; broken inside Docker
# because the container's bridge address is not reachable from outside).
#
# Default: "" (auto-detect)
#PUBLIC_HOST=192.168.1.130


# --- Build-time metadata (optional) ----------------------------------------
#
# These are typically set by the build script (`make build`, Dockerfile), not
# manually. They appear in /api/system/version and the login page footer.
#
#VMMANAGER_VERSION=dev
#VMMANAGER_BUILD_TIME=unknown


# --- Logging ----------------------------------------------------------------
#
# Format: "json" (structured, parseable) or "text" (human-readable).
# Level:  debug | info | warn | error
# Output: stderr (containers should redirect with docker logging driver).
#
# Default: json / info
#VMMANAGER_LOG_FORMAT=json
#VMMANAGER_LOG_LEVEL=info
#
# --- Optional file tee ---
#
# When set, every log record is also written (appended) to this
# file in the same format as stderr. The in-app "Logs" tab
# (/api/system/logs) reads from this file when present, so this
# is the canonical way to make logs available to the UI in a
# containerized deployment (where journalctl doesn't exist).
# Recommended: a path under DATA_DIR so the log is included in
# regular backups.
#
# Default: empty (stderr only)
#VMMANAGER_LOG_FILE=/opt/omv-vmmanager/logs/backend.log


# --- CORS -------------------------------------------------------------------
#
# Comma-separated list of allowed origins for CORS. "*" allows any.
# Set to your public URL in production.
#
# Default: *
#VMMANAGER_CORS_ORIGINS=*


# --- TLS / HTTPS -----------------------------------------------------------
#
# If you want omv-vmmanager to terminate TLS itself, configure these.
# Otherwise run behind a reverse proxy (Caddy, Traefik, nginx) that
# handles TLS.
#
#VMMANAGER_TLS_CERT=
#VMMANAGER_TLS_KEY=
#VMMANAGER_TLS_DOMAIN=


# --- Rate limiter bypass ---------------------------------------------------
#
# Comma-separated list of CIDRs that bypass the login rate limiter.
# Loopback (127.0.0.0/8, ::1) is ALWAYS trusted. This is for operators
# who have an external auth layer (VPN, SSO) and don't want their own
# admin CLI to be rate-limited when they fat-finger the password.
#
# DO NOT set this to 0.0.0.0/0 or any large CIDR that includes
# internet-facing IPs — the rate limiter is the only thing that
# protects /api/auth/login from online brute force.
#
# Default: empty (no extra trusted sources beyond loopback)
#VMMANAGER_TRUSTED_RATELIMIT_CIDRS=10.0.0.0/8,192.168.1.0/24


# --- Trust X-Forwarded-For -------------------------------------------------
#
# When omv-vmmanager sits BEHIND a reverse proxy (Caddy, Traefik, nginx),
# the proxy will set X-Forwarded-For to the real client IP. By default
# we IGNORE that header and use the TCP peer (i.e. the proxy's IP) for
# both logs and the rate limiter.
#
# Set to 1 ONLY if your reverse proxy is the only thing that can reach
# omv-vmmanager's port (e.g. localhost-only bind + TLS terminator), and
# the proxy strips any client-supplied X-Forwarded-For before adding
# its own.
#
# Default: 0 (don't trust)
#VMMANAGER_TRUST_PROXY=0


# .env loading
# ------------
# The backend automatically loads `.env` from the current working
# directory on startup, via godotenv. Missing file is not an error.
#
# Variables already set in the environment ALWAYS take precedence
# over values in .env (so a stale .env in the repo can't override
# a real systemd unit / compose env_file).
#
# To get a starter file, run from the repo root:
#   cp .env.example .env
# Then edit and `cd backend && make dev`.
#
# In production (systemd or Docker), .env is not required — set
# env vars in the unit file or compose env_file instead. .env is
# a developer convenience.
